# ---------------------------------------------------------------------
# AI / NVIDIA NIM
# ---------------------------------------------------------------------
# Crie uma conta no NVIDIA API Catalog para pegar sua chave gratuita:
# https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=sua_chave_nvidia_aqui
# OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

# ---------------------------------------------------------------------
# WHATSAPP CLOUD API (META)
# ---------------------------------------------------------------------
# Configure um Webhook no portal Meta for Developers
WHATSAPP_VERIFY_TOKEN=escolha_um_token_seguro_qualquer_exemplo_1234
WHATSAPP_API_TOKEN=seu_token_de_acesso_temporario_ou_permanente_da_api
WHATSAPP_PHONE_ID=id_do_numero_de_telefone_de_origem

# ---------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------
# (SQLite por padrão para testes locais)
# DATABASE_URL=sqlite+aiosqlite:///./bot.db
